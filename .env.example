# =============================================================================
# Strategaize Business System — Environment Variables (Beispiel)
# =============================================================================
# Diese Datei dokumentiert die wichtigsten ENV-Variablen.
# Lokale Werte stehen in `env vars_business.txt` (gitignored).
# Production-Werte werden in Coolify konfiguriert.
# =============================================================================

# -----------------------------------------------------------------------------
# Recording Retention (V5.2 — DSGVO-Datensparsamkeit, FEAT-521)
# -----------------------------------------------------------------------------
# Anzahl Tage, nach denen Rohaufnahmen (WAV + MP4) automatisch geloescht werden.
# Ab V5.2 Default auf 7 Tage reduziert (vorher 30) — DSGVO Art. 5 Abs. 1 lit. e
# (Datenminimierung). Activities, AI-Summary und Transkript bleiben permanent
# in der DB. Nur Rohdaten werden frueher entfernt.
# Override moeglich (z.B. 14, 30) wenn betriebliche Gruende es erfordern.
RECORDING_RETENTION_DAYS=7

# -----------------------------------------------------------------------------
# Transcription (V5.2 — DEC-085, DEC-086, FEAT-522)
# -----------------------------------------------------------------------------
# Provider fuer Audio-Transkription: openai (US, Default) | azure (EU, optional)
# Azure-Aktivierung erst Pre-Go-Live mit echtem Account und gesetzten Azure-ENVs.
# Adapter-Code ist ab V5.2 voll implementiert (vorher Stub).
TRANSCRIPTION_PROVIDER=openai

# Azure OpenAI (Whisper) — vor Go-Live setzen, dann TRANSCRIPTION_PROVIDER=azure
# Region muss EU sein (westeurope oder germanywestcentral) per data-residency.md
# AZURE_OPENAI_ENDPOINT=https://<resource>.<region>.openai.azure.com
# AZURE_OPENAI_API_KEY=<azure-portal-key>
# AZURE_OPENAI_WHISPER_DEPLOYMENT_ID=<deployment-id-aus-azure-studio>
# AZURE_OPENAI_API_VERSION=2024-06-01    # Default, ueber ENV uebersteuerbar (DEC-086)
