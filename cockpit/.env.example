# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Supabase — Dual URL Strategy
# ============================================================
# Server-side (internal Docker network in production, localhost in dev)
SUPABASE_URL=http://localhost:8000

# Client-side (browser — reverse proxy in production, localhost in dev)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000

# Auth keys (generate with: supabase gen keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret (min 32 chars, must match across GoTrue + PostgREST + Kong)
JWT_SECRET=your-jwt-secret-min-32-characters-here

# ============================================================
# Database
# ============================================================
POSTGRES_PASSWORD=your-strong-password-here

# ============================================================
# Storage
# ============================================================
STORAGE_FILE_SIZE_LIMIT=209715200

# ============================================================
# SMTP (E-Mail-Versand)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=your-email@gmail.com

# ============================================================
# AWS Bedrock (KI / LLM)
# ============================================================
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_REGION=eu-central-1
