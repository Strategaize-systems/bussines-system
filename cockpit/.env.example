# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Supabase — Dual URL Strategy
# ============================================================
# Server-side (internal Docker network in production, localhost in dev)
SUPABASE_URL=http://localhost:8000

# Client-side (browser — reverse proxy in production, localhost in dev)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000

# Auth keys (generate with: supabase gen keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret (min 32 chars, must match across GoTrue + PostgREST + Kong)
JWT_SECRET=your-jwt-secret-min-32-characters-here

# ============================================================
# Database
# ============================================================
POSTGRES_PASSWORD=your-strong-password-here

# ============================================================
# Storage
# ============================================================
STORAGE_FILE_SIZE_LIMIT=209715200

# ============================================================
# SMTP (E-Mail-Versand)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=your-email@gmail.com

# ============================================================
# AWS Bedrock (KI / LLM)
# ============================================================
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_REGION=eu-central-1

# ============================================================
# Cal.com Self-Hosted (FEAT-406, SLC-407)
# ============================================================
CALCOM_DB_PASSWORD=your-calcom-db-password-here
CALCOM_NEXTAUTH_SECRET=your-calcom-nextauth-secret-here
CALCOM_ENCRYPTION_KEY=your-calcom-encryption-key-here
CALCOM_PUBLIC_URL=https://cal.strategaizetransition.com
CALCOM_API_KEY=your-calcom-api-key-here
CALCOM_WEBHOOK_SECRET=your-calcom-webhook-secret-here
CALCOM_INTERNAL_URL=http://calcom:3000
CALCOM_BOOKING_PATH=/your-username/30min

# ============================================================
# Whisper / Speech-to-Text (FEAT-401, SLC-413)
# ============================================================
# Provider: openai (default) | azure | selfhosted
TRANSCRIPTION_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# ============================================================
# Jitsi JWT (FEAT-404, SLC-414)
# ============================================================
JITSI_JWT_APP_SECRET=your-jitsi-jwt-app-secret-here
JITSI_JWT_APP_ID=business
JITSI_XMPP_DOMAIN=meet.jitsi
JITSI_PUBLIC_DOMAIN=meet.strategaizetransition.com
