// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderBrandedHtml > empty-fallback: branding=null gibt identischen Output wie textToHtml (AC4) 1`] = `"<!DOCTYPE html><html><body>Hallo {{vorname}},<br /><br />vielen Dank fuer dein Interesse.<br /><br />Beste Gruesse</body></html>"`;

exports[`renderBrandedHtml > full-branding: rendert Logo, Footer-Linie, Kontakt-Block + Footer-Text (AC5) 1`] = `"<!DOCTYPE html><html><head><meta charset="utf-8" /></head><body style="margin:0;padding:0;font-family:Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;background:#ffffff;"><table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:600px;margin:0 auto;padding:24px;"><tr><td style="padding:0 0 24px 0;"><img src="https://example.com/logo.png" alt="Logo" style="max-height:48px;border:0;display:block;" /></td></tr><tr><td style="padding:0 0 24px 0;font-size:14px;line-height:1.5;color:#1f2937;">Hallo Anna,<br /><br />vielen Dank fuer dein Interesse.<br /><br />Beste Gruesse</td></tr><tr><td style="padding:0;border-top:2px solid #ff6600;font-size:0;line-height:0;">&nbsp;</td></tr><tr><td style="padding:16px 0 0 0;font-size:12px;line-height:1.5;color:#374151;"><strong>Anna Beispiel</strong><br />Strategaize GmbH<br />+49 30 1234567<br /><a href="https://strategaize.de" style="color:#ff6600;text-decoration:none;">https://strategaize.de</a></td></tr><tr><td style="padding:16px 0 0 0;font-size:12px;line-height:1.4;color:#6b7280;">Strategaize GmbH<br />Musterstrasse 1, 12345 Berlin</td></tr></table></body></html>"`;

exports[`renderBrandedHtml > logo-only: rendert Logo + Default-Primaerfarbe als Footer-Linie 1`] = `"<!DOCTYPE html><html><head><meta charset="utf-8" /></head><body style="margin:0;padding:0;font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Helvetica Neue", sans-serif;background:#ffffff;"><table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:600px;margin:0 auto;padding:24px;"><tr><td style="padding:0 0 24px 0;"><img src="https://example.com/logo-only.png" alt="Logo" style="max-height:48px;border:0;display:block;" /></td></tr><tr><td style="padding:0 0 24px 0;font-size:14px;line-height:1.5;color:#1f2937;">Hallo Anna,<br /><br />vielen Dank fuer dein Interesse.<br /><br />Beste Gruesse</td></tr><tr><td style="padding:0;border-top:2px solid #4454b8;font-size:0;line-height:0;">&nbsp;</td></tr></table></body></html>"`;
